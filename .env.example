# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.
# When deploying, set these same variables in the Vercel project's
# Settings > Environment Variables (do NOT put secrets in vercel.json or code).

MAILERLITE_API_KEY=eyJ0eX...-MTg
MAILERLITE_GROUP_ID=

# CMS auth
JWT_SECRET=change-this-to-a-random-string

# Vercel Postgres (auto-provided when you enable Vercel Postgres)
# POSTGRES_URL=postgres://...
# POSTGRES_PRISMA_URL=postgres://...
# POSTGRES_URL_NON_POOLING=postgres://...
